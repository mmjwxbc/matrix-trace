{
  "$schema": "../../tmp/pi/node_modules/wrangler/config-schema.json",
  "name": "matrix-trace-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-18",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "APP_ENV": "production",
    "OPENAI_BASE_URL": "https://api.deepseek.com",
    "PI_MODEL_PROVIDER": "custom-openai",
    "PI_MODEL_ID": "deepseek-v4-flash",
    "PI_SESSION_NAMESPACE": "pi-worker-poc"
  },
  "d1_databases": [
    {
      "binding": "CHAT_DB",
      "database_name": "matrix-trace-chat",
      "database_id": "37eec810-9b86-44a5-9aae-a69d421b257d",
      "migrations_dir": "./migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDurableObject" },
      { "name": "SESSION_REGISTRY_DO", "class_name": "SessionRegistryDurableObject" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDurableObject"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["SessionRegistryDurableObject"]
    }
  ],
  "env": {
    "staging": {
      "name": "matrix-trace-api-staging",
      "d1_databases": [
        {
          "binding": "CHAT_DB",
          "database_name": "matrix-trace-chat-staging",
          "database_id": "82f98204-bae2-45cf-a187-e3ef75488c96",
          "migrations_dir": "./migrations"
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDurableObject" },
          { "name": "SESSION_REGISTRY_DO", "class_name": "SessionRegistryDurableObject" }
        ]
      },
      "vars": {
        "APP_ENV": "staging",
        "PI_SESSION_NAMESPACE": "pi-worker-poc-staging"
      }
    },
    "production": {
      "name": "matrix-trace-api",
      "d1_databases": [
        {
          "binding": "CHAT_DB",
          "database_name": "matrix-trace-chat",
          "database_id": "37eec810-9b86-44a5-9aae-a69d421b257d",
          "migrations_dir": "./migrations"
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDurableObject" },
          { "name": "SESSION_REGISTRY_DO", "class_name": "SessionRegistryDurableObject" }
        ]
      },
      "vars": {
        "APP_ENV": "production",
        "OPENAI_BASE_URL": "https://api.deepseek.com",
        "PI_MODEL_PROVIDER": "custom-openai",
        "PI_MODEL_ID": "deepseek-v4-flash",
        "PI_SESSION_NAMESPACE": "pi-worker-poc"
      }
    }
  }
}
